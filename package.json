{
  "name": "orkllm",
  "version": "0.8.0-alpha.56",
  "description": "OpenAI-compatible local LLM inference server and admin dashboard for Rockchip NPU",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev:server": "node --watch src/server.js",
    "install:addon": "node-gyp rebuild",
    "build:frontend": "cd frontend && npm run build",
    "dev:frontend": "cd frontend && npm run dev",
    "test:unit": "node --test test/**/*.mjs",
    "test:e2e": "rm -f test_auth.json test_auth.db && npx playwright test",
    "test:sso": "docker compose -f docker-compose.test.yml up -d && ORKLLM_TEST_MOCK_OIDC_URL=http://localhost:8080/realms/orkllm npx playwright test --grep 'SSO'",
    "test:sso:down": "docker compose -f docker-compose.test.yml down"
  },
  "keywords": [
    "rkllm",
    "rockchip",
    "npu",
    "llm",
    "fastify",
    "vue3",
    "vuetify"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.2",
    "@langfuse/client": "^5.4.1",
    "@langfuse/otel": "^5.4.1",
    "@langfuse/tracing": "^5.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.1",
    "node-addon-api": "^8.3.0",
    "node-sqlite3-wasm": "^0.8.58",
    "openid-client": "^6.8.4",
    "samlify": "^2.13.1",
    "systeminformation": "^5.25.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "node-gyp": "^11.0.0",
    "semantic-release": "^24.2.9"
  }
}
