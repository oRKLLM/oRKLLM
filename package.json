{
  "name": "orkllm",
  "version": "0.1.0",
  "description": "OpenAI-compatible local LLM inference server and admin dashboard for Rockchip NPU",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev:server": "node --watch src/server.js",
    "install:addon": "node-gyp rebuild",
    "build:frontend": "cd frontend && npm run build",
    "dev:frontend": "cd frontend && npm run dev",
    "test:e2e": "rm -f test_auth.json test_auth.db && npx playwright test"
  },
  "keywords": [
    "rkllm",
    "rockchip",
    "npu",
    "llm",
    "fastify",
    "vue3",
    "vuetify"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.0.4",
    "@fastify/websocket": "^11.0.2",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.1",
    "node-addon-api": "^8.3.0",
    "systeminformation": "^5.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "node-gyp": "^11.0.0",
    "semantic-release": "^24.2.9"
  }
}
