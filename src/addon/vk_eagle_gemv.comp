#version 450
#extension GL_EXT_shader_16bit_storage                   : require
#extension GL_EXT_shader_explicit_arithmetic_types_int16 : require

// Optimized Cooperative GEMV for Mali GPU (Mesa / panvk)
// One workgroup per output element. Individual threads in workgroup load 
// elements in a coalesced fashion and perform cooperative reduction.

layout(local_size_x = 128) in;

layout(set=0, binding=0) readonly buffer In  { float    inp[];  };  // [IN_DIM]
layout(set=0, binding=1) readonly buffer W   { uint16_t w[];    };  // [OUT_DIM * IN_DIM] BF16
layout(set=0, binding=2)          buffer Out { float    outp[]; };  // [OUT_DIM]

// Shared push-constant block (u0,u1,f0) used by all Eagle shaders.
// gemv uses u0=OUT_DIM, u1=IN_DIM.
layout(push_constant) uniform PC { uint u0; uint u1; float f0; } pc;

float bf16_to_f32(uint16_t b) { return uintBitsToFloat(uint(b) << 16u); }

shared float s_data[128];

void main() {
    uint out_idx = gl_WorkGroupID.x;
    uint OUT_DIM = pc.u0;
    uint IN_DIM  = pc.u1;
    if (out_idx >= OUT_DIM) return;

    uint tid = gl_LocalInvocationID.x;
    float acc = 0.0;
    uint row_base = out_idx * IN_DIM;

    // Coalesced loads of input and weights!
    for (uint i = tid; i < IN_DIM; i += 128u) {
        acc += inp[i] * bf16_to_f32(w[row_base + i]);
    }

    s_data[tid] = acc;
    barrier();

    // Standard workgroup reduction
    for (uint stride = 64u; stride > 0u; stride /= 2u) {
        if (tid < stride) {
            s_data[tid] += s_data[tid + stride];
        }
        barrier();
    }

    if (tid == 0u) {
        outp[out_idx] = s_data[0];
    }
}
