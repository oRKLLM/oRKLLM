#version 450
#extension GL_EXT_shader_16bit_storage                   : require
#extension GL_EXT_shader_explicit_arithmetic_types_int16 : require

// Eagle-3 draft head: BF16 matrix-vector multiply (no bias).
//
//   out[OUT_DIM] = W[OUT_DIM x IN_DIM] @ in[IN_DIM]
//
// Weight is row-major BF16 ([out, in] as stored by PyTorch nn.Linear),
// input/output are FP32. One invocation per output element; dispatch
// ceil(OUT_DIM / 128) workgroups.

layout(local_size_x = 128) in;

layout(set=0, binding=0) readonly buffer In  { float    inp[];  };  // [IN_DIM]
layout(set=0, binding=1) readonly buffer W   { uint16_t w[];    };  // [OUT_DIM * IN_DIM] BF16
layout(set=0, binding=2)          buffer Out { float    outp[]; };  // [OUT_DIM]

// Shared push-constant block (u0,u1,f0) used by all Eagle shaders so a
// single pipeline layout serves every pipeline. gemv uses u0=OUT_DIM, u1=IN_DIM.
layout(push_constant) uniform PC { uint u0; uint u1; float f0; } pc;

float bf16_to_f32(uint16_t b) { return uintBitsToFloat(uint(b) << 16u); }

void main() {
    uint out_idx = gl_GlobalInvocationID.x;
    uint OUT_DIM = pc.u0;
    uint IN_DIM  = pc.u1;
    if (out_idx >= OUT_DIM) return;

    float acc = 0.0;
    uint row_base = out_idx * IN_DIM;
    for (uint i = 0u; i < IN_DIM; i++)
        acc += inp[i] * bf16_to_f32(w[row_base + i]);

    outp[out_idx] = acc;
}
