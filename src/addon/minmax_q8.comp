#version 450
#extension GL_EXT_shader_16bit_storage                   : require
#extension GL_EXT_shader_8bit_storage                    : require
#extension GL_EXT_shader_explicit_arithmetic_types_int16 : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8  : require

// Min-max INT8 quantisation: per-vector scale = max(|v|) / 127
// Output: FP32 scale (binding 2) + INT8 values (binding 1)
layout(local_size_x = 128) in;

layout(set=0, binding=0) readonly buffer InBuf    { uint16_t in_fp16[];   };
layout(set=0, binding=1) buffer          OutI8    { int8_t   out_i8[];    };
layout(set=0, binding=2) buffer          OutScale { float    out_scale[]; };

shared float shared_abs[128];

float unpack_fp16(uint16_t h) {
    uint u = uint(h);
    uint s = (u >> 15u) & 1u;
    uint e = (u >> 10u) & 0x1fu;
    uint m = u & 0x3ffu;
    if (e == 0u)  return (s != 0u ? -1.0 : 1.0) * (float(m) / 1024.0) * exp2(-14.0);
    if (e == 31u) return (s != 0u ? -1.0 : 1.0) * (1.0/0.0);
    return (s != 0u ? -1.0 : 1.0) * (1.0 + float(m)/1024.0) * exp2(float(int(e) - 15));
}

void main() {
    uint vec_idx = gl_WorkGroupID.x;
    uint dim     = gl_LocalInvocationID.x;
    uint in_idx  = vec_idx * 128u + dim;
    float val    = unpack_fp16(in_fp16[in_idx]);

    // Parallel max-abs reduction
    shared_abs[dim] = abs(val);
    memoryBarrierShared();
    barrier();

    for (uint stride = 64u; stride > 0u; stride >>= 1u) {
        if (dim < stride) shared_abs[dim] = max(shared_abs[dim], shared_abs[dim + stride]);
        memoryBarrierShared();
        barrier();
    }

    float max_abs   = shared_abs[0];
    float inv_scale = (max_abs == 0.0) ? 0.0 : 127.0 / max_abs;
    int   q         = clamp(int(round(val * inv_scale)), -127, 127);
    out_i8[in_idx]  = int8_t(q);

    if (dim == 0u)
        out_scale[vec_idx] = (max_abs == 0.0) ? 1.0 : max_abs / 127.0;
}
