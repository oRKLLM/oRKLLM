#version 450
#extension GL_EXT_shader_16bit_storage                   : require
#extension GL_EXT_shader_8bit_storage                    : require
#extension GL_EXT_shader_explicit_arithmetic_types_int16 : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8  : require

// Polar INT4 quantisation: L2 norm + unit-direction quantised to [-7,7] packed as nibbles.
// Each thread handles one of 128 dimensions.
// Output: FP16 norm (binding 2) + 64 packed INT4 bytes (binding 1, 2 dims per byte).
layout(local_size_x = 128) in;

layout(set=0, binding=0) readonly buffer InBuf    { uint16_t in_fp16[];    };
layout(set=0, binding=1) buffer          OutPacked { uint8_t out_packed[]; };
layout(set=0, binding=2) buffer          OutNorm  { uint16_t out_norm[];   };

shared float shared_sq[128];  // squared values for norm reduction
shared int   sq[128];         // INT4 direction values before nibble packing

float unpack_fp16(uint16_t h) {
    uint u = uint(h);
    uint s = (u >> 15u) & 1u;
    uint e = (u >> 10u) & 0x1fu;
    uint m = u & 0x3ffu;
    if (e == 0u)  return (s != 0u ? -1.0 : 1.0) * (float(m) / 1024.0) * exp2(-14.0);
    if (e == 31u) return (s != 0u ? -1.0 : 1.0) * (1.0/0.0);
    return (s != 0u ? -1.0 : 1.0) * (1.0 + float(m)/1024.0) * exp2(float(int(e) - 15));
}

uint16_t pack_fp16(float f) {
    if (f == 0.0) return uint16_t(0u);
    uint s = (f < 0.0) ? 1u : 0u;
    f = abs(f);
    int e16 = int(floor(log2(f))) + 15;
    if (e16 >= 31) return uint16_t((s << 15u) | 0x7c00u);
    if (e16 <= 0)  return uint16_t(s << 15u);
    uint frac = uint(round((f * exp2(float(15 - e16)) - 1.0) * 1024.0));
    if (frac >= 1024u) { frac = 0u; e16++; }
    if (e16 >= 31) return uint16_t((s << 15u) | 0x7c00u);
    return uint16_t((s << 15u) | (uint(e16) << 10u) | frac);
}

void main() {
    uint vec_idx = gl_WorkGroupID.x;
    uint dim     = gl_LocalInvocationID.x;
    uint in_idx  = vec_idx * 128u + dim;
    float val    = unpack_fp16(in_fp16[in_idx]);

    // Step 1: L2 norm via parallel reduction
    shared_sq[dim] = val * val;
    memoryBarrierShared();
    barrier();

    for (uint stride = 64u; stride > 0u; stride >>= 1u) {
        if (dim < stride) shared_sq[dim] += shared_sq[dim + stride];
        memoryBarrierShared();
        barrier();
    }

    // Step 2: quantise direction to INT4 range [-7,7]
    float norm     = sqrt(shared_sq[0]);
    float inv_norm = (norm > 0.0) ? (7.0 / norm) : 0.0;
    sq[dim]        = clamp(int(round(val * inv_norm)), -7, 7);
    memoryBarrierShared();
    barrier();

    // Step 3: pack pairs of INT4 values into one byte (dims 0..63 only)
    if (dim < 64u) {
        int lo = sq[dim * 2u];
        int hi = sq[dim * 2u + 1u];
        out_packed[vec_idx * 64u + dim] = uint8_t((lo & 0x0F) | ((hi & 0x0F) << 4));
    }

    if (dim == 0u)
        out_norm[vec_idx] = pack_fp16(norm);
}
